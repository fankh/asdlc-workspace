# Item 1 — LLM execution mode
# anthropic = fast, smart, paid API
# ollama    = local, private, free, slower
LLM_PROVIDER=anthropic
LLM_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-sonnet-4-6

# Local LLM fallback (used only when LLM_PROVIDER=ollama)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3:70b

# Item 2 — Project type (must match .pipeline/config.yaml)
PROJECT_TYPE=b2b_console

# Item 6 — Refinement circuit breaker
PIPELINE_MAX_REFINEMENT_LOOPS=5
PIPELINE_AUTO_COMMIT=true
PIPELINE_PARALLEL_AGENTS=false

# Build environment
NODE_OPTIONS=--max-old-space-size=4096
